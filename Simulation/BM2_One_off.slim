// ============================================================================
// CONSERVATION SIMULATION MODEL (SLiM – nonWF)
// ----------------------------------------------------------------------------
// Strategy: One-off supplementation
//
// Populations:
//   p0 = Wild population (disease present)
//   p1 = Insurance population (disease-free)
//
// Scenario (Benefit 2):
//   Beneficial mutation (m2) increases longevity by reducing disease mortality
//   (i.e., infected individuals carrying m2 survive longer and can progress to
//   an additional infection year/state).
//
// Objective:
//   Evaluate effects of supplementation on demography, disease dynamics,
//   genetic diversity, and spread of a beneficial mutation.
//
// Simulation terminates at extinction or generation 25700.
// ============================================================================


initialize()
{
	initializeSLiMModelType("nonWF");  // Non–Wright-Fisher model
	initializeSex("A");                // Autosomal chromosome model

	// -----------------------------
	// Demographic Parameters
	// -----------------------------
	defineConstant("FecuS", FecS);     // Fecundity of susceptible individuals
	defineConstant("FecuI", FecI);     // Fecundity of infected individuals

	defineConstant("WPSW", K2);        // Carrying capacity: wild population
	defineConstant("IPSI", K1);        // Carrying capacity: insurance population

	// -----------------------------
	// Supplementation Parameters
	// -----------------------------
	defineConstant("NMIP", MIP);       // Males transferred to establish insurance population
	defineConstant("NFIP", FIP);       // Females transferred to establish insurance population
	defineConstant("NFMI", NFM);       // Females supplemented from insurance → wild population
	// defineConstant("NMMI", NMM);    // (Optional) males supplemented from insurance → wild

	// -----------------------------
	// Infection Status Tags (age-structured infection states)
	// -----------------------------
	defineConstant("DEVILS_S", 0);     // Susceptible (uninfected)
	defineConstant("DEVILS_IY1", 1);   // Infected – Year 1
	defineConstant("DEVILS_IY2", 2);   // Infected – Year 2
	defineConstant("DEVILS_IY3", 3);   // Infected – Year 3
	defineConstant("DEVILS_IY4", 4);   // Infected – Year 4 (only reachable for m2 carriers)

	// -----------------------------
	// Disease Parameters
	// -----------------------------
	defineConstant("InitInf", IniInf);           // Initial number of infected individuals
	defineConstant("ProbiInf", ProbInf);         // Infection transmission scaling factor
	defineConstant("ProbDeath", ProDeath);       // Mortality probability: IY1 (non-m2)
	defineConstant("ProbDeathy2", ProDeathy2);   // Mortality probability: IY2 (non-m2)

	// Mortality probabilities for infected individuals carrying m2 (longevity benefit)
	defineConstant("ProbDeath_M2", ProDeath_M2);       // Mortality probability: IY1 (m2 carriers)
	defineConstant("ProbDeathy2_M2", ProDeathy2_M2);   // Mortality probability: IY2 (m2 carriers)
	defineConstant("ProbDeathy3_M2", ProDeathy3_M2);   // Mortality probability: IY3 (m2 carriers)

	defineConstant("ProbaRePro", ProbRePro);     // Reproduction probability if either parent is infected

	// -----------------------------
	// Age Structure Parameters
	// -----------------------------
	defineConstant("MAX_AGEWP", 7.0);  // Maximum age: wild population
	defineConstant("MAX_AGEIP", 8.0);  // Maximum age: insurance population
	defineConstant("AgeM", Age);       // Age of supplemented migrants
	defineConstant("AgeNB", HMB);      // Minimum reproductive age
	defineConstant("AgeMin", AgeInf);  // Minimum age eligible for infection

	// -----------------------------
	// Genomic Parameters
	// -----------------------------
	defineConstant("LC", L);           // Chromosome length (e.g., 30 Mb)
	defineConstant("MUR", MU);         // Mutation rate
	defineConstant("RecR", RR);        // Recombination rate

	initializeMutationType("m1", 0.5, "f", 0.0); // Neutral mutations
	initializeMutationType("m2", 0.5, "f", 0.0); // Beneficial mutation (longevity via reduced disease mortality)
	initializeGenomicElementType("g1", m1, 1);
	initializeMutationRate(MU);

	m2.convertToSubstitution = F;
	m1.convertToSubstitution = T;

	initializeGenomicElement(g1, 0, L); // Uniform chromosome
	initializeRecombinationRate(RR);
}


// -----------------------------------------------------------------------------
// REPRODUCTION: Wild Population (p0)
// Healthy and infected adults contribute with infection-dependent fecundity.
// Female eligibility differs for m2 carriers vs non-carriers (infection stages).
// -----------------------------------------------------------------------------

reproduction(p0, "F")
{
	// Select reproductive males (susceptible or Year-1 infected)
	malesS = p0.subsetIndividuals(sex="M", tag=DEVILS_S,  minAge=HMB, maxAge=6);
	malesI = p0.subsetIndividuals(sex="M", tag=DEVILS_IY1, minAge=HMB, maxAge=6);
	males  = c(malesS, malesI);

	// Identify candidate females and partition by mutation status (m2 carriers vs non-carriers)
	allFemales = p0.subsetIndividuals(sex="F", minAge=2, maxAge=5);
	has_m2 = (allFemales.countOfMutationsOfType(m2) > 0);
	FemalesWithBM    = allFemales[has_m2];
	FemalesWithoutBM = allFemales[!has_m2];

	// Female eligibility rules by infection stage:
	//   - m2 carriers: allow S, IY1, IY2
	//   - non-carriers: allow S, IY1
	candidateFemalesWithBM     = FemalesWithBM[FemalesWithBM.tag == DEVILS_S | FemalesWithBM.tag == DEVILS_IY1 | FemalesWithBM.tag == DEVILS_IY2];
	candiadteFemalesWithoutBM  = FemalesWithoutBM[FemalesWithoutBM.tag == DEVILS_S | FemalesWithoutBM.tag == DEVILS_IY1];

	females = c(candidateFemalesWithBM, candiadteFemalesWithoutBM);
	females = sample(females, size(females), replace=F); // Randomize female order

	for (female in females)
	{
		// Mate selection (males may mate multiple times)
		mate = sample(males, 1, replace=T);

		// Determine litter size:
		//   - If both parents susceptible: fecundity FecS
		//   - Otherwise: reproduction occurs with probability ProbRePro and fecundity FecI
		if (female.tag == DEVILS_S & mate.tag == DEVILS_S)
			litterSize = min(rpois(1, FecS), 4);
		else if (runif(1) < ProbRePro)
			litterSize = min(rpois(1, FecI), 4);
		else
			litterSize = 0;

		// Generate offspring (all offspring start as susceptible)
		if (litterSize > 0)
		{
			for (i in seqLen(litterSize))
			{
				offspring = p0.addCrossed(female, mate);
				offspring.tag = DEVILS_S;
			}
		}
	}
	self.active = 0;
}


// -----------------------------------------------------------------------------
// REPRODUCTION: Insurance Population (p1)
// Disease-free reproduction under density regulation.
// -----------------------------------------------------------------------------

reproduction(p1, "F")
{
	males = p1.subsetIndividuals(sex="M", minAge=Age, maxAge=6);
	females = p1.subsetIndividuals(sex="F", minAge=Age, maxAge=5);
	females = sample(females, size(females), replace=F);

	for (female in females)
	{
		mate = sample(males, 1, replace=T);
		litterSize = min(rpois(1, FecS), 4);

		for (i in seqLen(litterSize))
			p1.addCrossed(female, mate);
	}
	self.active = 0;
}


// -----------------------------------------------------------------------------
// GENERATION 25000
// Burn-in import, insurance establishment, and initial infection seeding.
// -----------------------------------------------------------------------------

25000 early()
{
	// Import pre-simulated burn-in population
	sim.readFromPopulationFile("/u/hknigus/scripts/Trial_sim.trees");
	p0.individuals.tag = DEVILS_S;

	// Establish insurance population (founders sampled from wild)
	sim.addSubpop("p1", 0);

	adult_females = p0.subsetIndividuals(sex="F", tag=DEVILS_S, minAge=1, maxAge=4);
	migrants_f = sample(adult_females, FIP, replace=F);

	adult_males = p0.subsetIndividuals(sex="M", tag=DEVILS_S, minAge=1, maxAge=4);
	migrants_m = sample(adult_males, MIP, replace=F);

	p1.takeMigrants(migrants_f);
	p1.takeMigrants(migrants_m);

	// Seed infection in wild population
	infected_Year1 = p0.sampleIndividuals(IniInf, replace=F, tag=DEVILS_S, minAge=2);
	infected_Year1.tag = DEVILS_IY1;
}


// -----------------------------------------------------------------------------
// GENERATION 25003
// Introduce beneficial mutation (m2) into a single random genome.
// -----------------------------------------------------------------------------

25003 early()
{
	target = sample(p0.individuals.genomes, 1);
	target.addNewDrawnMutation(m2, rdunif(1, 0, 30000000));
}


// -----------------------------------------------------------------------------
// GENERATION 25006
// One-off supplementation (insurance → wild): female migrants of age Age.
// -----------------------------------------------------------------------------

25006 early()
{
	migF = p1.sampleIndividuals(NFM, sex="F", minAge=Age, maxAge=Age);
	migF.tag = DEVILS_S;
	p0.takeMigrants(migF);
}


// -----------------------------------------------------------------------------
// EARLY() CALLBACK
// Density regulation, age-based mortality, infection transmission and progression.
// -----------------------------------------------------------------------------

early()
{
	// -----------------------------
	// Density regulation + age mortality: insurance population
	// -----------------------------
	indsIP = p1.individuals;
	indsIP.fitnessScaling = K1 / p1.individualCount;

	agesIP = indsIP.age;
	indsIP[agesIP > 8].fitnessScaling = 0.0;
	age_mortalityIP = sqrt((MAX_AGEIP - agesIP) / MAX_AGEIP);
	indsIP.fitnessScaling= indsIP.fitnessScaling*age_mortalityIP;

	// -----------------------------
	// Density regulation + age mortality: wild population
	// -----------------------------
	indsWP = p0.individuals;
	agesWP = indsWP.age;

	indsWP.fitnessScaling = K2 / p0.individualCount;

	age_mortalityWP = sqrt((MAX_AGEWP - agesWP) / MAX_AGEWP);
	indsWP[agesWP >= 7].fitnessScaling = 0.0;
	indsWP.fitnessScaling= age_mortalityWP*indsWP.fitnessScaling ;

	// -----------------------------
	// Infection transmission
	// -----------------------------
	uninfected  = p0.sampleIndividuals(p0.individualCount, tag=DEVILS_S);

	infected_Y1 = p0.sampleIndividuals(p0.individualCount, tag=DEVILS_IY1, minAge=AgeInf);
	infected_Y2 = p0.sampleIndividuals(p0.individualCount, tag=DEVILS_IY2, minAge=AgeInf);
	infected_Y3 = p0.sampleIndividuals(p0.individualCount, tag=DEVILS_IY3, minAge=AgeInf);
	infected_Y4 = p0.sampleIndividuals(p0.individualCount, tag=DEVILS_IY4, minAge=AgeInf);

	infected = c(infected_Y1, infected_Y2, infected_Y3, infected_Y4);

	// Infection probability scales with number of infected individuals
	PropI = min(1.0, ProbInf * infected.size());

	// New infections among susceptible individuals
	num_transmissions = rbinom(1, uninfected.size(), PropI);
	targets = sample(uninfected, num_transmissions, replace=F);
	targets.tag = DEVILS_IY1;

	// -----------------------------
	// Infection progression and mortality
	// m2 carriers experience reduced mortality and can reach IY4
	// -----------------------------
	for (inf in infected)
	{
		has_m2 = (inf.countOfMutationsOfType(m2) > 0);

		if (has_m2)
		{
			// Mortality progression for m2 carriers (longevity benefit)
			if (inf.tag == DEVILS_IY1)
			{
				if (runif(1) < ProDeath_M2) sim.killIndividuals(inf);
				else inf.tag = DEVILS_IY2;
			}
			else if (inf.tag == DEVILS_IY2)
			{
				if (runif(1) < ProDeathy2_M2) sim.killIndividuals(inf);
				else inf.tag = DEVILS_IY3;
			}
			else if (inf.tag == DEVILS_IY3)
			{
				if (runif(1) < ProDeathy3_M2) sim.killIndividuals(inf);
				else inf.tag = DEVILS_IY4;
			}
			else
			{
				// All Year-4 infected individuals die at end of stage
				sim.killIndividuals(inf);
			}
		}
		else
		{
			// Mortality progression for non-carriers (baseline)
			if (inf.tag == DEVILS_IY1)
			{
				if (runif(1) < ProDeath) sim.killIndividuals(inf);
				else inf.tag = DEVILS_IY2;
			}
			else if (inf.tag == DEVILS_IY2)
			{
				if (runif(1) < ProDeathy2) sim.killIndividuals(inf);
				else inf.tag = DEVILS_IY3;
			}
			else
			{
				// All Year-3 infected individuals die at end of stage
				sim.killIndividuals(inf);
			}
		}
	}
}


// -----------------------------------------------------------------------------
// LATE() CALLBACK
// Summary output.
// -----------------------------------------------------------------------------

late()
{
	// Terminate simulation early if wild population goes extinct
	if (p0.individualCount == 0)
		sim.simulationFinished();
	else
	{
		males = sum(p0.individuals.sex == "M" & p0.individuals.age >= 2 & p0.individuals.age <= 6);
		females = sum(p0.individuals.sex == "F" & p0.individuals.age >= 2 & p0.individuals.age <= 5);

		// Demography summary
		WPS = p0.individualCount;                // Wild population size
		IPS = p1.individualCount;                // Insurance population size
		WPMaxAge = max(p0.individuals.age);      // Max age (wild)
		IPMaxAge = max(p1.individuals.age);      // Max age (insurance)
		AveageWP = mean(p0.individuals.age);     // Mean age (wild)
		AveageIP = mean(p1.individuals.age);     // Mean age (insurance)

		// Fitness summary by infection status and mutation presence
		uninfected  = p0.sampleIndividuals(p0.individualCount, tag=DEVILS_S);
		infected_Y1 = p0.sampleIndividuals(p0.individualCount, tag=DEVILS_IY1);
		infected_Y2 = p0.sampleIndividuals(p0.individualCount, tag=DEVILS_IY2);
		infected_Y3 = p0.sampleIndividuals(p0.individualCount, tag=DEVILS_IY3);
		infected_Y4 = p0.sampleIndividuals(p0.individualCount, tag=DEVILS_IY4);
		infected = c(infected_Y1, infected_Y2, infected_Y3, infected_Y4);

		all_uninfected_hasm2 = (uninfected.countOfMutationsOfType(m2) >= 1);
		all_infected_hasm2   = (infected.countOfMutationsOfType(m2) >= 1);

		uninfected_hasm2    = uninfected[all_uninfected_hasm2];
		infected_hasm2      = infected[all_infected_hasm2];
		infected_nothasM2   = infected[!all_infected_hasm2];
		uninfected_nothasM2 = uninfected[!all_uninfected_hasm2];

		mean_fitness = mean(p0.cachedFitness(NULL));                 // Mean fitness (wild)
		D_fitness = mean(p0.cachedFitness(infected.index));          // Mean fitness (infected)
		ND_fitness = mean(p0.cachedFitness(uninfected.index));       // Mean fitness (uninfected)

		infected_Ben_fitness   = mean(p0.cachedFitness(infected_hasm2.index));
		uinfected_Ben_fitness  = mean(p0.cachedFitness(uninfected_hasm2.index));
		infected_noBen_fitness = mean(p0.cachedFitness(infected_nothasM2.index));
		uninfected_noBen_fitness = mean(p0.cachedFitness(uninfected_nothasM2.index));

		// Infection counts and prevalence
		Suscepl = uninfected.size();
		infected_Y1Tot = infected_Y1.size();
		infected_Y2Tot = infected_Y2.size();
		infected_Y3Tot = infected_Y3.size();
		infected_Y4Tot = infected_Y4.size();

		Infectedl = infected_Y1Tot + infected_Y2Tot + infected_Y3Tot + infected_Y4Tot;
		Prop_Inf = Infectedl / WPS;

		// Beneficial mutation summary
		all = p0.individuals;
		mut2 = sum(all.genomes.countOfMutationsOfType(m2) > 0);      // Number of genomes carrying m2
		Prop_Ben = mut2 / (2 * size(all));                           // Beneficial allele frequency

		Num_Ben = mut2 / 2;                                          // Approx. number of beneficial alleles (diploid scaling)
		Num_Ben_Individuals = sum(all.countOfMutationsOfType(m2) > 0);// Number of individuals carrying ≥1 copy of m2
		Prop_Bencheck = Num_Ben_Individuals / size(all);             // Proportion of individuals carrying m2

		// Heterozygosity
		Heterozygosity  = calcHeterozygosity(p1.genomes);            // Insurance heterozygosity
		Heterozygosity2 = calcHeterozygosity(p0.genomes);            // Wild heterozygosity

		mutw1 = sim.mutationsOfType(m1);
		mutw2 = sim.mutationsOfType(m2);
		Funhet2 = calcHeterozygosity(p0.genomes, mutw2);             // Functional heterozygosity
		Neuhet2 = calcHeterozygosity(p0.genomes, mutw1);             // Neutral heterozygosity

		// Inbreeding load
		Inbreeding2 = calcInbreedingLoad(p0.genomes);                // Wild: whole genome
		Inbreeding2fun = calcInbreedingLoad(p0.genomes, m2);         // Wild: functional
		Inbreeding2neut = calcInbreedingLoad(p0.genomes, m1);        // Wild: neutral

		Inbreeding = calcInbreedingLoad(p1.genomes);                 // Insurance: whole genome
		Inbreedingneut = calcInbreedingLoad(p1.genomes, m1);         // Insurance: neutral

		// Output: one comma-separated line per generation
		catn(sim.cycle + "," + WPS + "," + mean_fitness + "," + Funhet2 + "," + Heterozygosity2 + "," +
		     WPMaxAge + "," + IPMaxAge + "," + IPS + "," + Heterozygosity + "," + AveageIP + "," +
		     Suscepl + "," + Infectedl + "," + infected_Y1Tot + "," + infected_Y2Tot + "," +
		     infected_Y3Tot + "," + Prop_Inf + "," + Prop_Ben + "," + D_fitness + "," + ND_fitness + "," +
		     infected_Ben_fitness + "," + uinfected_Ben_fitness + "," + infected_noBen_fitness + "," +
		     uninfected_noBen_fitness + "," + Inbreeding + "," + Inbreedingneut + "," + Inbreeding2 + "," +
		     Inbreeding2fun + "," + Inbreeding2neut + "," + males + "," + females + "," + Num_Ben + "," +
		     Num_Ben_Individuals + "," + Prop_Bencheck);
	}
}


// -----------------------------------------------------------------------------
// FORCED TERMINATION
// -----------------------------------------------------------------------------

25700 late()
{
	sim.simulationFinished();
}