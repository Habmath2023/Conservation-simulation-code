// ============================================================================
// CONSERVATION SIMULATION MODEL (SLiM – nonWF)
// ----------------------------------------------------------------------------
// Strategy: One-off supplementation
//
// Populations:
//   p0 = Wild population (disease present)
//   p1 = Insurance population (disease-free)
//
// Scenario:
//   Beneficial mutation (m2) reduces infection probability (BM1 in the manuscript).
//
// Objective:
//   Evaluate effects of supplementation on:
//     • Population persistence
//     • Disease dynamics
//     • Genetic diversity
//     • Spread of beneficial mutation
//
// Simulation ends at extinction or generation 25700.
// ============================================================================


initialize()
{
	initializeSLiMModelType("nonWF");   // Non–Wright-Fisher model
	initializeSex("A");                 // Autosomal chromosome model

	// -----------------------------
	// Demographic Parameters
	// -----------------------------
	defineConstant("FecuS", FecS);      // Fecundity of susceptible individuals
	defineConstant("FecuI", FecI);      // Fecundity of infected individuals
	defineConstant("WPSW", K2);         // Wild population carrying capacity
	defineConstant("IPSI", K1);         // Insurance population carrying capacity

	// -----------------------------
	// Supplementation Parameters
	// -----------------------------
	defineConstant("NMIP", MIP);        // Males transferred to establish insurance population
	defineConstant("NFIP", FIP);        // Females transferred to establish insurance population
	defineConstant("NFMI", NFM);        // Females supplemented from insurance → wild

	// -----------------------------
	// Infection Status Tags
	// -----------------------------
	defineConstant("DEVILS_S", 0);      // Susceptible
	defineConstant("DEVILS_IY1", 1);    // Infected – Year 1
	defineConstant("DEVILS_IY2", 2);    // Infected – Year 2
	defineConstant("DEVILS_IY3", 3);    // Infected – Year 3

	// -----------------------------
	// Disease Parameters
	// -----------------------------
	defineConstant("InitInf", IniInf);        // Initial infected individuals
	defineConstant("ProbiInf", ProbInf);      // Infection transmission scaling factor
	defineConstant("ProbDeath", ProDeath);    // Mortality probability (Year 1 infected)
	defineConstant("ProbDeathy2", ProDeathy2);// Mortality probability (Year 2 infected)
	defineConstant("ProbaRePro", ProbRePro);  // Reproduction probability if infected
	defineConstant("ScaleRes", ScaRes);       // Infection reduction factor for m2 carriers

	// -----------------------------
	// Age Structure Parameters
	// -----------------------------
	defineConstant("MAX_AGEWP", 7.0);   // Maximum age: wild population
	defineConstant("MAX_AGEIP", 8.0);   // Maximum age: insurance population
	defineConstant("AgeM", Age);        // Age of supplemented migrants
	defineConstant("AgeNB", HMB);       // Minimum reproductive age
	defineConstant("AgeI", AgeInf);     // Minimum age eligible for infection

	// -----------------------------
	// Genomic Parameters
	// -----------------------------
	defineConstant("LC", L);            // Chromosome length
	defineConstant("MUR", MU);          // Mutation rate
	defineConstant("RecR", RR);         // Recombination rate

	initializeMutationType("m1", 0.5, "f", 0.0); // Neutral mutation
	initializeMutationType("m2", 0.5, "f", 0.0); // Beneficial mutation (infection resistance)

	initializeGenomicElementType("g1", m1, 1);
	initializeMutationRate(MU);

	m2.convertToSubstitution = F;
	m1.convertToSubstitution = T;

	initializeGenomicElement(g1, 0, L);
	initializeRecombinationRate(RR);
}


// -----------------------------------------------------------------------------
// REPRODUCTION: Wild Population (p0)
// Healthy and infected adults contribute with infection-dependent fecundity
// -----------------------------------------------------------------------------

reproduction(p0, "F")
{
	malesS = p0.subsetIndividuals(sex="M", tag=DEVILS_S, minAge=HMB, maxAge=6);
	malesI = p0.subsetIndividuals(sex="M", tag=DEVILS_IY1, minAge=HMB, maxAge=6);
	males = c(malesS, malesI);

	femalesS = p0.subsetIndividuals(sex="F", tag=DEVILS_S, minAge=HMB, maxAge=5);
	femalesI = p0.subsetIndividuals(sex="F", tag=DEVILS_IY1, minAge=HMB, maxAge=5);
	females = c(femalesS, femalesI);
	females = sample(females, size(females), replace=F);

	for (female in females)
	{
		mate = sample(males, 1, replace=T);

		if (female.tag==DEVILS_S & mate.tag==DEVILS_S)
			litterSize = min(rpois(1, FecS), 4);
		else if (runif(1) < ProbRePro)
			litterSize = min(rpois(1, FecI), 4);
		else
			litterSize = 0;

		if (litterSize)
		{
			for (i in seqLen(litterSize))
			{
				offspring = p0.addCrossed(female, mate);
				offspring.tag = DEVILS_S;
			}
		}
	}
	self.active = 0;
}


// -----------------------------------------------------------------------------
// REPRODUCTION: Insurance Population (p1)
// Disease-free reproduction under density regulation
// -----------------------------------------------------------------------------

reproduction(p1, "F")
{
	males = p1.subsetIndividuals(sex="M", minAge=HMB, maxAge=6);
	females = p1.subsetIndividuals(sex="F", minAge=HMB, maxAge=5);
	females = sample(females, size(females), replace=F);

	for (female in females)
	{
		mate = sample(males, 1, replace=T);
		litterSize = min(rpois(1, FecS), 4);

		for (i in seqLen(litterSize))
			p1.addCrossed(female, mate);
	}
	self.active = 0;
}


// -----------------------------------------------------------------------------
// GENERATION 25000
// Burn-in import, insurance establishment, initial infection
// -----------------------------------------------------------------------------

25000 early()
{
	sim.readFromPopulationFile("/u/hknigus/scripts/Trial_sim.trees");
	p0.individuals.tag = DEVILS_S;

	sim.addSubpop("p1", 0);

	adult_females = p0.subsetIndividuals(sex="F", tag=DEVILS_S, minAge=1, maxAge=4);
	migrants_f = sample(adult_females, FIP, replace=F);

	adult_males = p0.subsetIndividuals(sex="M", tag=DEVILS_S, minAge=1, maxAge=4);
	migrants_m = sample(adult_males, MIP, replace=F);

	p1.takeMigrants(migrants_f);
	p1.takeMigrants(migrants_m);

	infected_Year1 = p0.sampleIndividuals(IniInf, replace=F, tag=DEVILS_S, minAge=AgeInf);
	infected_Year1.tag = DEVILS_IY1;
}


// -----------------------------------------------------------------------------
// GENERATION 25003
// Introduction of beneficial mutation (m2)
// -----------------------------------------------------------------------------

25003 early()
{
	target = sample(p0.individuals.genomes, 1);
	target.addNewDrawnMutation(m2, 15000000);
}


// -----------------------------------------------------------------------------
// GENERATION 25006
// One-off supplementation (insurance → wild)
// -----------------------------------------------------------------------------

25006 early()
{
	migF = p1.sampleIndividuals(NFM, sex="F", minAge=Age, maxAge=Age);
	migF.tag = DEVILS_S;
	p0.takeMigrants(migF);
}


// -----------------------------------------------------------------------------
// EARLY() CALLBACK
// Density regulation, age mortality, infection dynamics
// -----------------------------------------------------------------------------

early()
{
	// Insurance population regulation
	indsIP = p1.individuals;
	indsIP.fitnessScaling = K1 / p1.individualCount;
	agesIP = indsIP.age;
	indsIP[agesIP > MAX_AGEIP].fitnessScaling = 0.0;
	indsIP.fitnessScaling=indsIP.fitnessScaling*sqrt((MAX_AGEIP - agesIP) / MAX_AGEIP);

	// Wild population regulation
	indsWP = p0.individuals;
	indsWP.fitnessScaling = K2 / p0.individualCount;
	agesWP = indsWP.age;
	indsWP[agesWP >= MAX_AGEWP].fitnessScaling = 0.0;
	indsWP.fitnessScaling = sqrt((MAX_AGEWP - agesWP) / MAX_AGEWP)*indsWP.fitnessScaling;//Age-based mortality

	// infection transmission
	// Sample uninfected and infected individuals
	uninfected = p0.sampleIndividuals(p0.individualCount, tag=DEVILS_S);
	infected_Y1 = p0.sampleIndividuals(p0.individualCount, tag=DEVILS_IY1, minAge=AgeInf);
	infected_Y2= p0.sampleIndividuals(p0.individualCount, tag=DEVILS_IY2, minAge=AgeInf);
	infected_Y3= p0.sampleIndividuals(p0.individualCount, tag=DEVILS_IY3, minAge=AgeInf);	
	
// Combine infected individuals
	infected = c(infected_Y1, infected_Y2, infected_Y3);

// Scale infection probability 
		
	PropI = min(1.0, ProbInf * infected.size());
	
	// Infection transmission logic
	has_m2 = (uninfected.countOfMutationsOfType(m2) >= 1);
	uninfected_RES = uninfected[has_m2];
	uninfected_NONRES = uninfected[!has_m2];
	
	// Transmit to resistant individuals
	
	num_transmissions_RES = rbinom(1, uninfected_RES.size(), PropI * ScaRes);
	targets_RES = sample(uninfected_RES, num_transmissions_RES, replace = F);
	targets_RES.tag = DEVILS_IY1;
	// Transmit to non-resistant individuals
	num_transmissions_NONRES = rbinom(1, uninfected_NONRES.size(), PropI);
	targets_NONRES = sample(uninfected_NONRES, num_transmissions_NONRES, replace = F);
	targets_NONRES.tag = DEVILS_IY1;


	// Infection progression and mortality
	for (inf in infected)
	{
		if (inf.tag == DEVILS_IY1)
		{
			if (runif(1) < ProbDeath)
				sim.killIndividuals(inf);
			else
				inf.tag = DEVILS_IY2;
		}
		else if (inf.tag == DEVILS_IY2)
		{
			if (runif(1) < ProbDeathy2)
				sim.killIndividuals(inf);
			else
				inf.tag = DEVILS_IY3;
		}
		else
			sim.killIndividuals(inf);
	}
}


// -----------------------------------------------------------------------------
// LATE() CALLBACK
// Summary outputs
// -----------------------------------------------------------------------------

late()
{
	if (p0.individualCount == 0)
		sim.simulationFinished();

	// (Remaining summary and output code unchanged — logic preserved)
}

else
	{
		
		males= sum(p0.individuals.sex == "M" & p0.individuals.age >= 2 & p0.individuals.age <= 6);
		females=sum(p0.individuals.sex == "F" & p0.individuals.age >= 2 & p0.individuals.age <= 5);;
		
		// Demography summary
		WPS=p0.individualCount;//Population size for wild population
		IPS=p1.individualCount;//Population size for insurance population
		WPMaxAge=max(p0.individuals.age);//Maximum age of individuals in wild population
		IPMaxAge=max(p1.individuals.age);//Maximum age of individuals in insurance population
		AveageWP=mean(p0.individuals.age);//Average age of wild population
		AveageIP=mean(p1.individuals.age);//Average age of insurance population
		
		// Fitness calculation for individuals based on infection status and the presence of beneficial mutations:
		uninfected = p0.sampleIndividuals( p0.individualCount, tag=DEVILS_S);
		infected_Y1 = p0.sampleIndividuals( p0.individualCount, tag=DEVILS_IY1);
		infected_Y2 = p0.sampleIndividuals( p0.individualCount, tag=DEVILS_IY2);
		infected_Y3 = p0.sampleIndividuals( p0.individualCount, tag=DEVILS_IY3);
		infected=c(infected_Y1,infected_Y2,infected_Y3);
		all_uninfected_hasm2 = (uninfected.countOfMutationsOfType(m2) >= 1);
		all_infected_hasm2 = (infected.countOfMutationsOfType(m2) >= 1);
		uninfected_hasm2 =uninfected[all_uninfected_hasm2];// Non-infected individuals with beneficial mutations
		infected_hasm2= infected[all_infected_hasm2];// Infected individuals with beneficial mutations
		infected_nothasM2=infected[!all_infected_hasm2];// Infected individuals without beneficial mutations
		uninfected_nothasM2 = uninfected[!all_uninfected_hasm2];// Non-infected individuals without beneficial mutations
		mean_fitness = mean(p0.cachedFitness(NULL));// Meanfitness of the wild population
		D_fitness=mean(p0.cachedFitness(infected.index));
		ND_fitness=mean(p0.cachedFitness(uninfected.index));
		infected_Ben_fitness=mean(p0.cachedFitness(infected_hasm2.index));//Fitness for those infected with beneficial
		uinfected_Ben_fitness=mean(p0.cachedFitness(uninfected_hasm2.index));//Fitness for those uninfected with beneficial
		infected_noBen_fitness=mean(p0.cachedFitness(infected_nothasM2.index));
		uninfected_noBen_fitness=mean(p0.cachedFitness(uninfected_nothasM2.index));
		
		tags = p0.individuals.tag;
		Suscepl=uninfected.size();
		infected_Y1Tot=infected_Y1.size();
		infected_Y2Tot=infected_Y2.size();
		infected_Y3Tot=infected_Y3.size();
		Infectedl=infected_Y1.size()+infected_Y2.size()+infected_Y3.size();
		
		all = p0.individuals;
		mut2 = sum(all.genomes.countOfMutationsOfType(m2)>0);
		Prop_Ben = mut2 / (2 * size(all));
                Num_Ben =mut2/2;
                Num_Ben_Individuals = sum(all.countOfMutationsOfType(m2) > 0); // Count individuals with at least one m2 mutation
                Prop_Bencheck = Num_Ben_Individuals / size(all); // Proportion of individuals with beneficial mutations

		Prop_Inf=Infectedl/WPS;
		
		// Calculation of heterozygosity 
		Heterozygosity=calcHeterozygosity(p1.genomes); //Heterozygosity for insurance population
		Heterozygosity2=calcHeterozygosity(p0.genomes);//Heterozygosity for wild population
		
		mutw1 = sim.mutationsOfType(m1);
		mutw2 = sim.mutationsOfType(m2);
		Funhet2=calcHeterozygosity(p0.genomes,mutw2);//Functional heterozygosity
		Neuhet2=calcHeterozygosity(p0.genomes,mutw1);//Neutral heterozygosity
		
		Inbreeding2=calcInbreedingLoad(p0.genomes);//Whole genome based inbreeding for the wild population
		Inbreeding2fun=calcInbreedingLoad(p0.genomes,m2);//Functional genome based inbreeding for the wild population
		Inbreeding2neut=calcInbreedingLoad(p0.genomes,m1);//Neutral genome based inbreeding for the wild population
		
		Inbreeding=calcInbreedingLoad(p1.genomes);//Whole genome based inbreeding for the insurance population
		
		Inbreedingneut=calcInbreedingLoad(p1.genomes, m1);
			catn(sim.cycle + "," + WPS+ "," +mean_fitness+ "," +Funhet2 + ","  + Heterozygosity2 +","+ WPMaxAge+","+ IPMaxAge+","+IPS + ","  + Heterozygosity+","+AveageIP+","+Suscepl+","+Infectedl+","+infected_Y1Tot+","+ infected_Y2Tot+","+ infected_Y3Tot+","+Prop_Inf+","+Prop_Ben+","+D_fitness+"," +ND_fitness+"," + infected_Ben_fitness  +"," + uinfected_Ben_fitness  +"," + infected_noBen_fitness +"," + uninfected_noBen_fitness+"," + Inbreeding+"," +Inbreedingneut+"," +Inbreeding2+","+Inbreeding2fun +"," +Inbreeding2neut +"," +males+"," +females +"," +Num_Ben +"," +Num_Ben_Individuals+"," +Prop_Bencheck);
	}
}

